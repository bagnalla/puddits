{
  "name": "puddi",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal object-oriented layer over the HTML5 canvas",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run build:ts && node build/esm/build.js",
    "build:min": "npm run build:ts && node build/esm/build.js --minify"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "terser": "^5.27.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "three": "^0.182.0"
  }
}
